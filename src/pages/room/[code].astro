---
import Layout from '../../layouts/Layout.astro';
import RoomViewComponent from '../../components/RoomView.tsx';

// Astro page config to allow SSR routing parameters
const { code } = Astro.params;
---

<Layout>
  <div class="relative min-h-screen flex flex-col p-4">
    <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
      <div class="absolute top-[10%] -left-[10%] w-[50%] h-[50%] rounded-full bg-indigo-600/5 blur-[120px] mix-blend-screen"></div>
      <div class="absolute bottom-[20%] -right-[5%] w-[40%] h-[40%] rounded-full bg-fuchsia-600/5 blur-[100px] mix-blend-screen"></div>
    </div>
    
    <div class="relative z-10 w-full flex-grow flex flex-col">
      <div class="w-full max-w-7xl mx-auto py-4 px-4 flex justify-between items-center mb-4">
        <a href="/" class="text-xl font-bold tracking-tight bg-gradient-to-br from-violet-400 to-indigo-600 bg-clip-text text-transparent hover:opacity-80 transition-opacity">
          Treachery MTG
        </a>
      </div>

      <RoomViewComponent roomCode={code || ''} client:load />
    </div>
  </div>
</Layout>
