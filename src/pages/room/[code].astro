---
import Layout from "../../layouts/Layout.astro";
import RoomViewComponent from "../../components/RoomView.tsx";

// Astro page config to allow SSR routing parameters
const { code } = Astro.params;
---

<Layout>
  <div class="relative flex min-h-screen flex-col p-4">
    <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div
        class="absolute top-[10%] -left-[10%] h-[50%] w-[50%] rounded-full bg-indigo-600/5 mix-blend-screen blur-[120px]"
      >
      </div>
      <div
        class="absolute -right-[5%] bottom-[20%] h-[40%] w-[40%] rounded-full bg-fuchsia-600/5 mix-blend-screen blur-[100px]"
      >
      </div>
    </div>

    <div class="relative z-10 flex w-full flex-grow flex-col">
      <RoomViewComponent roomCode={code || ""} client:load />
    </div>
  </div>
</Layout>
