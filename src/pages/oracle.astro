---
import Layout from "../layouts/Layout.astro";
import { db } from "../db";
import { cards } from "../db/schema";
import { Crown, Shield, Skull } from "lucide-react";
import { parseManaSymbols } from "../lib/mana";

const allCards = await db.select().from(cards);

const grouped = {
  Leader: allCards.filter((c) => c.subtype === "Leader"),
  Guardian: allCards.filter((c) => c.subtype === "Guardian"),
  Assassin: allCards.filter((c) => c.subtype === "Assassin"),
  Traitor: allCards.filter((c) => c.subtype === "Traitor"),
};

const rarityOrder = { M: 0, R: 1, U: 2, C: 3 };

const sortCards = (cardList: typeof allCards) =>
  cardList.sort((a, b) => {
    const rarityDiff = (rarityOrder[a.rarity as keyof typeof rarityOrder] ?? 4) - (rarityOrder[b.rarity as keyof typeof rarityOrder] ?? 4);
    if (rarityDiff !== 0) return rarityDiff;
    return a.name.localeCompare(b.name);
  });

const roles = [
  {
    name: "Leader",
    color: "amber",
    bgFrom: "from-amber-500/10",
    bgTo: "to-amber-600/5",
    border: "border-amber-500/20",
    icon: Crown,
    description: "You must discover and eliminate the Assassins and the Traitor. Survive at all costs. You begin the game revealed.",
    iconColor: "text-amber-500",
  },
  {
    name: "Guardian",
    color: "blue",
    bgFrom: "from-blue-500/10",
    bgTo: "to-blue-600/5",
    border: "border-blue-500/20",
    icon: Shield,
    description: "Your objective is to protect the Leader at all costs. You win if the Leader wins.",
    iconColor: "text-blue-500",
  },
  {
    name: "Assassin",
    color: "red",
    bgFrom: "from-red-500/10",
    bgTo: "to-red-600/5",
    border: "border-red-500/20",
    icon: null,
    emoji: "🗡️",
    description: "Your objective is to kill the Leader. You win if the Leader dies.",
    iconColor: "text-red-500",
  },
  {
    name: "Traitor",
    color: "purple",
    bgFrom: "from-purple-500/10",
    bgTo: "to-purple-600/5",
    border: "border-purple-500/20",
    icon: Skull,
    description: "Your objective is to be the last player standing. Eliminate the Assassins and the Guardian first, then kill the Leader.",
    iconColor: "text-purple-500",
  },
];

const rarityColors: Record<string, string> = {
  C: "bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300",
  U: "bg-green-500/20 text-green-600 dark:text-green-400",
  R: "bg-blue-500/20 text-blue-600 dark:text-blue-400",
  M: "bg-orange-500/20 text-orange-600 dark:text-orange-400",
};
---

<Layout>
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h1
        class="text-4xl md:text-5xl font-bold tracking-tight mb-6 bg-clip-text text-transparent bg-gradient-to-r from-slate-900 to-primary dark:from-white dark:to-primary/80"
      >
        Oracle
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Browse all Identity cards by role. Each card represents a secret allegiance in the game of Treachery.
      </p>
    </div>

    {roles.map((role) => {
      const roleCards = sortCards(grouped[role.name as keyof typeof grouped] || []);
      const IconComponent = role.icon;

      return (
        <section class="mb-16">
          <div class={`bg-gradient-to-br ${role.bgFrom} ${role.bgTo} border ${role.border} rounded-xl p-6 mb-6`}>
            <div class="flex items-center gap-3 mb-3">
              <div class={`w-12 h-12 bg-${role.color}-500 rounded-lg flex items-center justify-center`}>
                {role.emoji ? (
                  <span class="text-2xl">{role.emoji}</span>
                ) : IconComponent ? (
                  <IconComponent class="h-6 w-6 text-white" />
                ) : null}
              </div>
              <h2 class="text-2xl font-bold">{role.name}</h2>
              <span class="text-sm text-slate-500 dark:text-slate-400 ml-2">
                ({roleCards.length} {roleCards.length === 1 ? "card" : "cards"})
              </span>
            </div>
            <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed">
              {role.description}
            </p>
          </div>

          {roleCards.length === 0 ? (
            <div class="text-center py-12 text-slate-500 dark:text-slate-400">
              <p>No cards found for this role.</p>
            </div>
          ) : (
            <div class={`bg-slate-100 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden`}>
              <table class="w-full">
                <thead class="bg-slate-50 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
                  <tr>
                    <th class="text-left py-3 px-6 text-sm font-semibold text-slate-600 dark:text-slate-400">Card Name</th>
                    <th class="text-center py-3 px-6 text-sm font-semibold text-slate-600 dark:text-slate-400 w-32">Cost</th>
                    <th class="text-center py-3 px-6 text-sm font-semibold text-slate-600 dark:text-slate-400 w-24">Rarity</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                  {roleCards.map((card) => (
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/80 transition-colors">
                      <td class="py-3 px-6">
                        <a href={`/oracle/${card.nameAnchor}`} class="font-medium text-slate-900 dark:text-slate-100 hover:text-primary dark:hover:text-primary transition-colors">
                          {card.name}
                        </a>
                      </td>
                      <td class="py-3 px-6 text-center">
                        {card.cost && <span set:html={parseManaSymbols(card.cost)} />}
                      </td>
                      <td class="py-3 px-6 text-center">
                        <span class={`inline-flex items-center justify-center w-8 h-8 rounded-full text-sm font-bold ${rarityColors[card.rarity] || rarityColors.C}`}>
                          {card.rarity}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>
      );
    })}
  </div>
</Layout>
