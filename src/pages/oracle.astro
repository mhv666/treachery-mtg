---
import Layout from "../layouts/Layout.astro";
import { db } from "../db";
import { cards } from "../db/schema";
import { Crown, Shield, Skull } from "lucide-react";
import { parseManaSymbols } from "../lib/mana";

const allCards = await db.select().from(cards);

const grouped = {
  Leader: allCards.filter((c) => c.subtype === "Leader"),
  Guardian: allCards.filter((c) => c.subtype === "Guardian"),
  Assassin: allCards.filter((c) => c.subtype === "Assassin"),
  Traitor: allCards.filter((c) => c.subtype === "Traitor"),
};

const rarityOrder = { M: 0, R: 1, U: 2, C: 3 };

const sortCards = (cardList: typeof allCards) =>
  cardList.sort((a, b) => {
    const rarityDiff =
      (rarityOrder[a.rarity as keyof typeof rarityOrder] ?? 4) -
      (rarityOrder[b.rarity as keyof typeof rarityOrder] ?? 4);
    if (rarityDiff !== 0) return rarityDiff;
    return a.name.localeCompare(b.name);
  });

const roles = [
  {
    name: "Leader",
    color: "amber",
    bgFrom: "from-amber-500/10",
    bgTo: "to-amber-600/5",
    border: "border-amber-500/20",
    icon: Crown,
    description:
      "You must discover and eliminate the Assassins and the Traitor. Survive at all costs. You begin the game revealed.",
    iconColor: "text-amber-500",
  },
  {
    name: "Guardian",
    color: "blue",
    bgFrom: "from-blue-500/10",
    bgTo: "to-blue-600/5",
    border: "border-blue-500/20",
    icon: Shield,
    description:
      "Your objective is to protect the Leader at all costs. You win if the Leader wins.",
    iconColor: "text-blue-500",
  },
  {
    name: "Assassin",
    color: "red",
    bgFrom: "from-red-500/10",
    bgTo: "to-red-600/5",
    border: "border-red-500/20",
    icon: null,
    emoji: "🗡️",
    description:
      "Your objective is to kill the Leader. You win if the Leader dies.",
    iconColor: "text-red-500",
  },
  {
    name: "Traitor",
    color: "purple",
    bgFrom: "from-purple-500/10",
    bgTo: "to-purple-600/5",
    border: "border-purple-500/20",
    icon: Skull,
    description:
      "Your objective is to be the last player standing. Eliminate the Assassins and the Guardian first, then kill the Leader.",
    iconColor: "text-purple-500",
  },
];

const rarityColors: Record<string, string> = {
  C: "bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-300",
  U: "bg-green-500/20 text-green-600 dark:text-green-400",
  R: "bg-blue-500/20 text-blue-600 dark:text-blue-400",
  M: "bg-orange-500/20 text-orange-600 dark:text-orange-400",
};
---

<Layout>
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 text-center">
      <h1
        class="to-primary dark:to-primary/80 mb-6 bg-gradient-to-r from-slate-900 bg-clip-text text-4xl font-bold tracking-tight text-transparent md:text-5xl dark:from-white"
      >
        Oracle
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Browse all Identity cards by role. Each card represents a secret
        allegiance in the game of Treachery.
      </p>
    </div>

    {
      roles.map((role) => {
        const roleCards = sortCards(
          grouped[role.name as keyof typeof grouped] || [],
        );
        const IconComponent = role.icon;

        return (
          <section class="mb-16">
            <div
              class={`bg-gradient-to-br ${role.bgFrom} ${role.bgTo} border ${role.border} mb-6 rounded-xl p-6`}
            >
              <div class="mb-3 flex items-center gap-3">
                <div
                  class={`h-12 w-12 bg-${role.color}-500 flex items-center justify-center rounded-lg`}
                >
                  {role.emoji ? (
                    <span class="text-2xl">{role.emoji}</span>
                  ) : IconComponent ? (
                    <IconComponent class="h-6 w-6 text-white" />
                  ) : null}
                </div>
                <h2 class="text-2xl font-bold">{role.name}</h2>
                <span class="ml-2 text-sm text-slate-500 dark:text-slate-400">
                  ({roleCards.length}{" "}
                  {roleCards.length === 1 ? "card" : "cards"})
                </span>
              </div>
              <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">
                {role.description}
              </p>
            </div>

            {roleCards.length === 0 ? (
              <div class="py-12 text-center text-slate-500 dark:text-slate-400">
                <p>No cards found for this role.</p>
              </div>
            ) : (
              <div
                class={`overflow-hidden rounded-xl border border-slate-200 bg-slate-100 dark:border-slate-700 dark:bg-slate-800/50`}
              >
                <table class="w-full">
                  <thead class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-800">
                    <tr>
                      <th class="px-6 py-3 text-left text-sm font-semibold text-slate-600 dark:text-slate-400">
                        Card Name
                      </th>
                      <th class="w-32 px-6 py-3 text-center text-sm font-semibold text-slate-600 dark:text-slate-400">
                        Cost
                      </th>
                      <th class="w-24 px-6 py-3 text-center text-sm font-semibold text-slate-600 dark:text-slate-400">
                        Rarity
                      </th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                    {roleCards.map((card) => (
                      <tr class="transition-colors hover:bg-slate-50 dark:hover:bg-slate-800/80">
                        <td class="px-6 py-3">
                          <a
                            href={`/oracle/${card.nameAnchor}`}
                            class="hover:text-primary dark:hover:text-primary font-medium text-slate-900 transition-colors dark:text-slate-100"
                          >
                            {card.name}
                          </a>
                        </td>
                        <td class="px-6 py-3 text-center">
                          {card.cost && (
                            <span set:html={parseManaSymbols(card.cost)} />
                          )}
                        </td>
                        <td class="px-6 py-3 text-center">
                          <span
                            class={`inline-flex h-8 w-8 items-center justify-center rounded-full text-sm font-bold ${rarityColors[card.rarity] || rarityColors.C}`}
                          >
                            {card.rarity}
                          </span>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </section>
        );
      })
    }
  </div>
</Layout>
