---
import Layout from "../layouts/Layout.astro";
import HomeForms from "../components/HomeForms";
import HeroBanner from "../components/HeroBanner.astro";
---

<Layout>
  <HeroBanner />

  <div
    class="relative flex min-h-screen flex-col items-center justify-center p-4"
  >
    <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div
        class="absolute -top-[40%] -left-[10%] h-[70%] w-[70%] rounded-full bg-violet-600/10 mix-blend-screen blur-[120px]"
      >
      </div>
      <div
        class="absolute top-[60%] -right-[10%] h-[60%] w-[60%] rounded-full bg-indigo-600/10 mix-blend-screen blur-[100px]"
      >
      </div>
    </div>

    <div class="relative z-10 w-full">
      <HomeForms client:load />
    </div>
  </div>
</Layout>
